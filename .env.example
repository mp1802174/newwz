# ─── 微信公众号管理系统 环境变量 ───
# 复制此文件为 .env 并填入真实值
# 切勿将 .env 提交到 Git！

# Web 服务
WEB_HOST=0.0.0.0
WEB_PORT=5000
# 留空则自动生成随机密钥（每次重启会变，session 失效）
# 生产环境建议手动设置一个固定值：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# WZ 主库（存文章）
WZ_DB_HOST=127.0.0.1
WZ_DB_PORT=3306
WZ_DB_USER=cj
WZ_DB_PASSWORD=
WZ_DB_DATABASE=cj

# Discuz 论坛库（发帖）
DISCUZ_DB_HOST=127.0.0.1
DISCUZ_DB_PORT=3306
DISCUZ_DB_USER=00077
DISCUZ_DB_PASSWORD=
DISCUZ_DB_DATABASE=00077

# Discuz 发帖配置
FORUM_FID=2
FORUM_AUTHOR=砂鱼
FORUM_AUTHORID=4
